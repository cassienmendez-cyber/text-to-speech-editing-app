{
  "name": "storyscribe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "StoryScribe — an audio-first revision companion for authors.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/e2e.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@tauri-apps/api": "^2.11.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
